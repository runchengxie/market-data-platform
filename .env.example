# Copy to .env.local, or keep credentials in
# ~/.config/market-data-platform/secrets.env. Never commit credential values.

# Shared published asset root consumed by research repositories.
DATA_PLATFORM_ROOT=/data/market-data-platform

# CN provider credentials.
TUSHARE_TOKEN=
TUSHARE_TOKEN_2=

# RQData credentials used by HK assets and HK depth transition backends.
RQDATA_USERNAME=
RQDATA_PASSWORD=
RQDATA_URI=
